---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<Layout title="Writing — Ronit Kapur">
	<div class="writing-page">
		<div class="writing-inner">
			<header>
				<div class="sec-head">
					<span class="hash">#</span>
					<span class="name">writing</span>
					<span class="meta">{sortedPosts.length} {sortedPosts.length === 1 ? 'entry' : 'entries'}</span>
				</div>
				<hr />
			</header>

			{sortedPosts.length > 0 ? (
				<ol class="post-list">
					{sortedPosts.map((post) => (
						<li class="entry">
							<span class="tag">
								<time datetime={post.data.publishDate.toISOString()}>
									{post.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '-')}
								</time>
							</span>
							<div>
								<a class="post-title" href={`/blog/${post.slug}`}>{post.data.title}</a>
								{post.data.excerpt && <p class="excerpt">{post.data.excerpt}</p>}
							</div>
						</li>
					))}
				</ol>
			) : (
				<p class="empty">No transmissions yet — check back later. <span class="cursor">▮</span></p>
			)}
		</div>
	</div>
</Layout>

<style>
	.writing-page {
		min-height: 100vh;
		padding: 64px 24px 96px;
	}

	.writing-inner {
		max-width: 720px;
		margin: 0 auto;
	}

	header { margin-bottom: 32px; }

	.empty {
		color: var(--text-dimmer);
		font-style: italic;
		margin: 0;
	}

	.cursor {
		display: inline-block;
		color: var(--text);
		margin-left: 4px;
		font-style: normal;
		animation: blink 1.1s step-end infinite;
	}

	@keyframes blink {
		50% { opacity: 0; }
	}

	@media (prefers-reduced-motion: reduce) {
		.cursor { animation: none; opacity: 0.6; }
	}

	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.entry {
		display: grid;
		grid-template-columns: 96px 1fr;
		gap: 16px;
		margin-bottom: 22px;
	}

	.entry .tag {
		color: var(--text-dimmer);
		font-size: 12px;
		padding-top: 3px;
		white-space: nowrap;
	}

	.post-title {
		color: var(--text-strong);
		text-decoration: none;
		font-weight: 500;
		border-bottom: 1px dotted var(--dot);
		padding-bottom: 1px;
	}

	.post-title:hover { border-bottom-color: var(--text); }

	.excerpt {
		color: var(--text);
		margin: 6px 0 0;
		font-size: 13px;
		line-height: 1.6;
	}

	@media (max-width: 640px) {
		.entry {
			grid-template-columns: 1fr;
			gap: 4px;
		}
		.entry .tag { padding-top: 0; }
	}
</style>
