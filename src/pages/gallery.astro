---
import Layout from '../layouts/Layout.astro';

const galleryImages = [
  {
    src: "/gallery/whirlpool.jpg",
    width: 665,
    height: 957,
    alt: "Whirlpool Galaxy",
    title: "Whirlpool Galaxy (M51)",
    caption: "A grand-design spiral galaxy ~23 million light-years away, in Canes Venatici.",
  },
  {
    src: "/gallery/moon.JPG",
    width: 1080,
    height: 1920,
    alt: "Moon",
    title: "Full Moon",
    caption: "Lunar surface detail captured with a Seestar S50 telescope.",
  },
];
---

<Layout title="Gallery — Ronit Kapur">
  <link slot="head" rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5.4.2/dist/photoswipe.css">

  <div class="gallery-page">
    <div class="gallery-inner">
      <header>
        <div class="sec-head">
          <span class="hash">#</span>
          <span class="name">gallery</span>
          <span class="meta">{galleryImages.length} frames</span>
        </div>
        <hr />
        <p class="intro">Astrophotography projects. Click a frame to open.</p>
      </header>

      <div class="pswp-gallery" id="my-gallery">
        {galleryImages.map((image) => (
          <a
            href={image.src}
            data-pswp-width={image.width}
            data-pswp-height={image.height}
            target="_blank"
            class="frame"
          >
            <img src={image.src} alt={image.alt} loading="lazy" />
            <div class="caption">
              <span class="title">{image.title}</span>
              <span class="desc">{image.caption}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  .gallery-page {
    min-height: 100vh;
    padding: 64px 24px 96px;
  }

  .gallery-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  header { margin-bottom: 40px; max-width: 720px; }

  .intro {
    color: var(--text);
    margin: 0;
  }

  .pswp-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .frame {
    display: block;
    color: inherit;
    text-decoration: none;
    border: 1px solid var(--rule);
    transition: border-color 0.15s, transform 0.2s ease;
  }

  .frame:hover {
    border-color: var(--text-dimmer);
  }

  .frame img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    transition: opacity 0.2s;
  }

  .frame:hover img {
    opacity: 0.92;
  }

  .caption {
    padding: 12px 14px 14px;
    border-top: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .caption .title {
    color: var(--text-strong);
    font-size: 13px;
    font-weight: 500;
  }

  .caption .desc {
    color: var(--text-dimmer);
    font-size: 12px;
    line-height: 1.5;
  }

  /* PhotoSwipe overrides — match the mono/charcoal aesthetic */
  :global(.pswp) {
    --pswp-bg: rgba(10, 10, 10, 0.96);
  }

  :global(.pswp__button) { color: var(--text) !important; }
  :global(.pswp__counter) {
    color: var(--text-dimmer) !important;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px !important;
  }
</style>

<script type="module">
  import PhotoSwipeLightbox from 'https://cdn.jsdelivr.net/npm/photoswipe@5.4.2/dist/photoswipe-lightbox.esm.js';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#my-gallery',
    children: 'a',
    pswpModule: () => import('https://cdn.jsdelivr.net/npm/photoswipe@5.4.2/dist/photoswipe.esm.js'),
    showHideAnimationType: 'zoom',
    bgOpacity: 0.96,
    closeOnVerticalDrag: true,
    wheelToZoom: true,
  });
  lightbox.init();
</script>
