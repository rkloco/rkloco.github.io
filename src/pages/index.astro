---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ronit Kapur">
	<div class="log-page">
		<div class="sky" id="sky" aria-hidden="true"></div>
		<div class="log-inner">
			<header class="log-header">
				<h1>Ronit Kapur</h1>
				<p class="role">duke // cs + physics</p>
				<p class="loc">durham, nc</p>

				<div class="links">
					<a href="https://github.com/rkloco" target="_blank">github</a>
					<span class="sep">·</span>
					<a href="https://linkedin.com/in/ronit-kapur" target="_blank">linkedin</a>
					<span class="sep">·</span>
					<a href="https://x.com/rk_loco" target="_blank">x</a>
					<span class="sep">·</span>
					<a href="mailto:ronit.kapur@duke.edu">email</a>
					<span class="sep">·</span>
					<a href="/gallery">gallery</a>
					<span class="sep">·</span>
					<a href="/blog">writing</a>
					<span class="sep">·</span>
					<a href="/blog">misc</a>
				</div>

				<p class="blurb">
					Rising third-year at Duke University studying CS and Physics — concentrations in AI/ML and astrophysics along with a math minor. 
					I'm interested in developing technology that creates or uses fresh, insightful models of the world in its manifestation.
					I'm interested in profilerating this technology thoughtfully to make the world a better place.
					Previously at TJHSST in Alexandria, VA. Love meeting new people — always feel free to reach out. Views are my own. 
				</p>
			</header>

			<section>
				<div class="sec-head">
					<span class="hash">#</span>
					<span class="name">current_ops</span>
					<span class="meta">as of 2026-05</span>
				</div>
				<hr />

				<div class="entry">
					<span class="tag">T-3 mo</span>
					<p>Studying abroad at the <strong>University of Edinburgh</strong> for the fall semester.</p>
				</div>

				<div class="entry">
					<span class="tag">T+0 mo</span>
					<p>GNC engineering at <strong>SpaceX</strong> in Hawthorne, on the Starshield program. Designing and implementing guidance, navigation, and control algorithms, simulations, tools, and ops dashboards in support of national security.</p>
				</div>

				<div class="entry">
					<span class="tag">T+12 mo</span>
					<p>Lead software engineer at <strong>Liberata</strong>. Building an open-source academic publishing platform with peer-review and replication incentives — data infrastructure, file processing, integration of novel scholarly metrics.</p>
				</div>
			</section>

			<section>
				<div class="sec-head">
					<span class="hash">#</span>
					<span class="name">research_log</span>
				</div>
				<hr />

				<div class="entry">
					<span class="tag">2022–24</span>
					<p>Independent astrophysics research at <strong>UMD</strong> in collaboration with NASA, advised by Tad Komacek. Incorporated stellar gravity darkening into Navier-Stokes general circulation models — the most sophisticated atmospheric model of exoplanets at time of completion. Months-long simulations on UMD's Zaratan cluster. Presented at <strong>ISEF 2023</strong> in Dallas.</p>
				</div>

				<div class="entry">
					<span class="tag">2022–23</span>
					<p>Research at the <strong>U.S. Naval Research Laboratory</strong>. Modeled the solar magnetic field for space weather prediction and mitigation. Probed Faraday Rotation near the Sun using Parker Solar Probe ephemeris to identify optimal observation windows in support of a successful Very Large Array proposal. Presented at ISDC 2025 in Washington, D.C.</p>
				</div>
			</section>

			<section>
				<div class="sec-head">
					<span class="hash">#</span>
					<span class="name">industry_log</span>
				</div>
				<hr />

				<div class="entry">
					<span class="tag">summer 2025</span>
					<p>Policy research at the <strong>GWU Space Policy Institute</strong>. Wrote a technical report on space governance grounded in Svalbard and Tangier precedent.</p>
				</div>

				<div class="entry">
					<span class="tag">spring 2025</span>
					<p>Data engineer at <strong>Turbo AI</strong>. Helped scale an edtech AI startup from 1.5M to 3M users and past $3M ARR. PostHog instrumentation, retention and churn modeling, pricing and UI iteration.</p>
				</div>
			</section>

			<section>
				<div class="sec-head">
					<span class="hash">#</span>
					<span class="name">teaching</span>
				</div>
				<hr />

				<div class="entry">
					<span class="tag">spring 2026</span>
					<p>Help Room TA for <strong>Math 230 — Probability</strong>.</p>
				</div>

				<div class="entry">
					<span class="tag">fall 2025</span>
					<p>Help Room TA for <strong>Math 218D — Matrices &amp; Vectors</strong>, Duke's linear algebra course for engineers.</p>
				</div>
			</section>

			<section>
				<div class="sec-head">
					<span class="hash">#</span>
					<span class="name">recognition</span>
				</div>
				<hr />
				<p class="oneline">8VC × Meta × Duke Hackathon, 1st · ISEF Finalist · SciOly Astronomy 1st nationwide · National Merit Scholar · WTOP "Top Kid".</p>
			</section>
		</div>
	</div>
</Layout>

<style>
	.log-page {
		position: relative;
		min-height: 100vh;
		padding: 64px 24px 96px;
	}

	.sky {
		position: fixed;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		overflow: hidden;
	}

	.log-inner {
		position: relative;
		z-index: 2;
		max-width: 720px;
		margin: 0 auto;
	}

	.log-header {
		margin-bottom: 56px;
	}

	.log-header h1 {
		font-size: 28px;
		font-weight: 700;
		color: var(--text-strong);
		letter-spacing: -0.01em;
		margin: 0 0 4px;
	}

	.role { color: var(--text-dim); margin: 0; }
	.loc { color: var(--text-dimmer); margin: 0 0 18px; }

	.links {
		margin-bottom: 28px;
		color: var(--text-dimmer);
	}

	.links a {
		color: var(--text);
		text-decoration: none;
		border-bottom: 1px dotted var(--dot);
		padding-bottom: 1px;
		transition: border-color 0.15s, color 0.15s;
	}

	.links a:hover {
		color: var(--text-strong);
		border-bottom-color: var(--text);
	}

	.sep { color: var(--text-faint); margin: 0 8px; }

	.blurb { color: var(--text); margin: 0; }

	section { margin-bottom: 40px; }

	.entry {
		display: grid;
		grid-template-columns: 100px 1fr;
		gap: 16px;
		margin-bottom: 18px;
	}

	.tag {
		color: var(--text-dimmer);
		font-size: 12px;
		padding-top: 2px;
		white-space: nowrap;
	}

	.entry p { margin: 0; color: var(--text); }

	.entry strong {
		color: var(--text-strong);
		font-weight: 500;
		border-bottom: 1px dotted var(--dot);
		padding-bottom: 1px;
	}

	.oneline { color: var(--text); margin: 0; }

	.oneline a {
		color: var(--text-strong);
		text-decoration: none;
		border-bottom: 1px dotted var(--dot);
		padding-bottom: 1px;
	}
	.oneline a:hover { border-bottom-color: var(--text); }

	@media (max-width: 640px) {
		.entry {
			grid-template-columns: 1fr;
			gap: 4px;
		}
		.tag { padding-top: 0; }
	}
</style>

<script>
	function initShootingStars() {
		const sky = document.getElementById('sky');
		if (!sky) return;

		const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (reduce) return;

		function spawn() {
			const star = document.createElement('div');
			star.className = 'shooting-star';

			const W = window.innerWidth;
			const H = window.innerHeight;

			const startX = W * 0.2 + Math.random() * (W * 0.95);
			const startY = -40 - Math.random() * 80;

			const angleDeg = 110 + Math.random() * 50;
			const angleRad = angleDeg * Math.PI / 180;

			const dist = Math.hypot(W, H) * (0.9 + Math.random() * 0.4);
			const dx = Math.cos(angleRad) * dist;
			const dy = Math.sin(angleRad) * dist;

			const dur = 1100 + Math.random() * 900;

			star.style.left = startX + 'px';
			star.style.top = startY + 'px';
			star.style.setProperty('--dx', dx + 'px');
			star.style.setProperty('--dy', dy + 'px');
			star.style.setProperty('--angle', angleDeg + 'deg');
			star.style.animation = `shoot ${dur}ms cubic-bezier(0.4, 0.05, 0.6, 0.95) forwards`;
			const w = 80 + Math.random() * 70;
			star.style.width = w + 'px';
			star.style.opacity = String(0.7 + Math.random() * 0.3);

			sky.appendChild(star);
			setTimeout(() => star.remove(), dur + 100);
		}

		function loop() {
			spawn();
			if (Math.random() < 0.18) {
				setTimeout(spawn, 200 + Math.random() * 400);
			}
			const next = 3500 + Math.random() * 5000;
			setTimeout(loop, next);
		}

		let started = false;
		function start() {
			if (started) return;
			started = true;
			setTimeout(loop, 600);
		}
		if (document.visibilityState === 'visible') start();
		document.addEventListener('visibilitychange', () => {
			if (document.visibilityState === 'visible') start();
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initShootingStars);
	} else {
		initShootingStars();
	}
</script>
