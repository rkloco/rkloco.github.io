---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ronit Kapur">
	<div class="log-page">
		<div class="sky" id="sky" aria-hidden="true"></div>
		<div class="log-inner">
			<header class="log-header">
				<h1>Ronit Kapur</h1>
				<p class="role">duke // cs + physics // ai/ml + astrophysics</p>
				<p class="loc">durham, nc</p>

				<div class="links">
					<a href="https://github.com/rkloco" target="_blank">github</a>
					<span class="sep">·</span>
					<a href="https://linkedin.com/in/ronit-kapur" target="_blank">linkedin</a>
					<span class="sep">·</span>
					<a href="https://x.com/rk_loco" target="_blank">x</a>
					<span class="sep">·</span>
					<a href="mailto:ronit.kapur@duke.edu">email</a>
				</div>

				<p class="blurb">
					Second-year at Duke studying CS and Physics — concentrations in AI/ML and astrophysics, math minor. I like problems where the universe gives you noisy data and you have to figure out what it's telling you. Previously at TJHSST in Alexandria, where I co-led the Science Olympiad and Astronomy teams.
				</p>
			</header>

			<section>
				<div class="sec-head">
					<span class="hash">#</span>
					<span class="name">current_ops</span>
					<span class="meta">as of 2026-05</span>
				</div>
				<hr />

				<div class="entry">
					<span class="tag">T−3 mo</span>
					<p>Joining <strong>SpaceX</strong> in Hawthorne this summer as a GNC Engineering Intern on the Starshield program. Building guidance, navigation, and control algorithms, simulations, tools, and ops dashboards in support of national security.</p>
				</div>

				<div class="entry">
					<span class="tag">ongoing</span>
					<p>Backend engineer at <strong>Liberata</strong>. Building an open-source publishing platform with peer-review and replication incentives — OAuth, Supabase infrastructure, scholarly metrics, file processing.</p>
				</div>

				<div class="entry">
					<span class="tag">2025–</span>
					<p>Help Room TA for <strong>Math 218D — Matrices &amp; Vectors</strong>, Duke's linear algebra course for engineers.</p>
				</div>
			</section>

			<section>
				<div class="sec-head">
					<span class="hash">#</span>
					<span class="name">research_log</span>
				</div>
				<hr />

				<div class="entry">
					<span class="tag">2022–24</span>
					<p>Independent astrophysics research at <strong>UMD</strong> in collaboration with NASA, advised by Tad Komacek. Incorporated stellar gravity darkening into Navier-Stokes general circulation models — the most sophisticated atmospheric model of exoplanets at time of completion. Months-long simulations on UMD's Zaratan cluster. Presented at <strong>ISEF 2023</strong> in Dallas.</p>
				</div>

				<div class="entry">
					<span class="tag">2022–23</span>
					<p>Research intern at the <strong>U.S. Naval Research Laboratory</strong>. Modeled Faraday Rotation near the Sun using Parker Solar Probe ephemeris to identify optimal observation windows — supported a successful Very Large Array proposal.</p>
				</div>
			</section>

			<section>
				<div class="sec-head">
					<span class="hash">#</span>
					<span class="name">industry_log</span>
				</div>
				<hr />

				<div class="entry">
					<span class="tag">2025</span>
					<p>Data engineer at <strong>Turbo AI</strong>. Helped scale an edtech AI startup from 1.5M to 3M users and past $3M ARR. PostHog instrumentation, retention and churn modeling, pricing and UI iteration.</p>
				</div>

				<div class="entry">
					<span class="tag">2025</span>
					<p>Policy research intern at the <strong>GWU Space Policy Institute</strong>. Wrote a technical report on space governance grounded in Svalbard and Tangier precedent. Networked at ISDC 2025, learned alongside students at the International Space University in France.</p>
				</div>
			</section>

			<section>
				<div class="sec-head">
					<span class="hash">#</span>
					<span class="name">outreach</span>
				</div>
				<hr />

				<div class="entry">
					<span class="tag">2023</span>
					<p>Founded <strong>Space Summit DC</strong> — first space conference for DC-area high school students, hosted at UMD College Park. ~100 registrants from 20+ local schools, including Title I.</p>
				</div>

				<div class="entry">
					<span class="tag">2024</span>
					<p>Organized the <strong>TJ AI Symposium</strong>, the first HS-led AI symposium on governance and ethics. Moderated an hour-long, six-expert panel on AI in K-12 education for 250+ students, teachers, and Fairfax County school board members.</p>
				</div>

				<div class="entry">
					<span class="tag">2023</span>
					<p>Fellow at <strong>The SPRING Group</strong>. Co-authored a 20-page paper on youth recommendations for generative AI governance — accepted as material by the United Nations High-Level Advisory Body on AI.</p>
				</div>

				<div class="entry">
					<span class="tag">2024–</span>
					<p>Member of the Science Olympiad <strong>A-Team</strong> — nationwide network of astronomy event supervisors and test writers.</p>
				</div>
			</section>

			<section>
				<div class="sec-head">
					<span class="hash">#</span>
					<span class="name">awards</span>
				</div>
				<hr />
				<p class="oneline">8VC × Meta × Duke Hackathon, 1st · ISEF Finalist · SciOly Astronomy 1st nationwide · AIME qualifier · National Merit Scholar.</p>
			</section>

			<section>
				<div class="sec-head">
					<span class="hash">#</span>
					<span class="name">interests</span>
				</div>
				<hr />
				<p class="oneline">Astrophysics, financial markets &amp; derivatives, cybersecurity, quantum computing, reinforcement learning.</p>
			</section>

			<section>
				<div class="sec-head">
					<span class="hash">#</span>
					<span class="name">signal</span>
				</div>
				<hr />
				<p class="oneline">
					<a href="mailto:ronit.kapur@duke.edu">ronit.kapur@duke.edu</a>
					<span class="sep">·</span>
					<a href="/gallery">gallery</a>
					<span class="sep">·</span>
					<a href="/blog">writing</a>
					<span class="sep">·</span>
					always down to chat
					<span class="cursor">▮</span>
				</p>
			</section>
		</div>
	</div>
</Layout>

<style>
	.log-page {
		position: relative;
		min-height: 100vh;
		padding: 64px 24px 96px;
	}

	.sky {
		position: fixed;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		overflow: hidden;
	}

	.log-inner {
		position: relative;
		z-index: 2;
		max-width: 720px;
		margin: 0 auto;
	}

	.log-header {
		margin-bottom: 56px;
	}

	.log-header h1 {
		font-size: 28px;
		font-weight: 700;
		color: var(--text-strong);
		letter-spacing: -0.01em;
		margin: 0 0 4px;
	}

	.role { color: var(--text-dim); margin: 0; }
	.loc { color: var(--text-dimmer); margin: 0 0 18px; }

	.links {
		margin-bottom: 28px;
		color: var(--text-dimmer);
	}

	.links a {
		color: var(--text);
		text-decoration: none;
		border-bottom: 1px dotted var(--dot);
		padding-bottom: 1px;
		transition: border-color 0.15s, color 0.15s;
	}

	.links a:hover {
		color: var(--text-strong);
		border-bottom-color: var(--text);
	}

	.sep { color: var(--text-faint); margin: 0 8px; }

	.blurb { color: var(--text); margin: 0; }

	section { margin-bottom: 40px; }

	.entry {
		display: grid;
		grid-template-columns: 84px 1fr;
		gap: 16px;
		margin-bottom: 18px;
	}

	.tag {
		color: var(--text-dimmer);
		font-size: 12px;
		padding-top: 2px;
		white-space: nowrap;
	}

	.entry p { margin: 0; color: var(--text); }

	.entry strong {
		color: var(--text-strong);
		font-weight: 500;
		border-bottom: 1px dotted var(--dot);
		padding-bottom: 1px;
	}

	.oneline { color: var(--text); margin: 0; }

	.oneline a {
		color: var(--text-strong);
		text-decoration: none;
		border-bottom: 1px dotted var(--dot);
		padding-bottom: 1px;
	}
	.oneline a:hover { border-bottom-color: var(--text); }

	.cursor {
		display: inline-block;
		color: var(--text);
		margin-left: 6px;
		animation: blink 1.1s step-end infinite;
	}

	@keyframes blink {
		50% { opacity: 0; }
	}

	@media (max-width: 640px) {
		.entry {
			grid-template-columns: 1fr;
			gap: 4px;
		}
		.tag { padding-top: 0; }
	}

	@media (prefers-reduced-motion: reduce) {
		.cursor { animation: none; opacity: 0.6; }
	}
</style>

<script>
	function initShootingStars() {
		const sky = document.getElementById('sky');
		if (!sky) return;

		const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (reduce) return;

		function spawn() {
			const star = document.createElement('div');
			star.className = 'shooting-star';

			const W = window.innerWidth;
			const H = window.innerHeight;

			const startX = W * 0.2 + Math.random() * (W * 0.95);
			const startY = -40 - Math.random() * 80;

			const angleDeg = 110 + Math.random() * 50;
			const angleRad = angleDeg * Math.PI / 180;

			const dist = Math.hypot(W, H) * (0.9 + Math.random() * 0.4);
			const dx = Math.cos(angleRad) * dist;
			const dy = Math.sin(angleRad) * dist;

			const dur = 1100 + Math.random() * 900;

			star.style.left = startX + 'px';
			star.style.top = startY + 'px';
			star.style.setProperty('--dx', dx + 'px');
			star.style.setProperty('--dy', dy + 'px');
			star.style.setProperty('--angle', angleDeg + 'deg');
			star.style.animation = `shoot ${dur}ms cubic-bezier(0.4, 0.05, 0.6, 0.95) forwards`;
			const w = 80 + Math.random() * 70;
			star.style.width = w + 'px';
			star.style.opacity = String(0.7 + Math.random() * 0.3);

			sky.appendChild(star);
			setTimeout(() => star.remove(), dur + 100);
		}

		function loop() {
			spawn();
			if (Math.random() < 0.18) {
				setTimeout(spawn, 200 + Math.random() * 400);
			}
			const next = 3500 + Math.random() * 5000;
			setTimeout(loop, next);
		}

		let started = false;
		function start() {
			if (started) return;
			started = true;
			setTimeout(loop, 600);
		}
		if (document.visibilityState === 'visible') start();
		document.addEventListener('visibilitychange', () => {
			if (document.visibilityState === 'visible') start();
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initShootingStars);
	} else {
		initShootingStars();
	}
</script>
